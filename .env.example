# ─── GOD API Environment Variables ───────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database (MongoDB) ────────────────────────────────────────────────────────
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/god_api
# MongoDB Atlas (replace with your Atlas connection string):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/god_api

# ── Redis (Rate Limiting Store — optional) ────────────────────────────────────
# If REDIS_URL is unset, rate limiting falls back to in-memory automatically.
# Use Redis for multi-instance / production deployments.
REDIS_URL=redis://localhost:6379
# MongoDB Atlas (replace with your Atlas connection string):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/god_api

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Global limit per API key (all providers combined)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Per-provider limits per API key (req/min). Omit to use defaults.
RATE_LIMIT_OPENAI=20
RATE_LIMIT_STRIPE=100
RATE_LIMIT_GITHUB=30
RATE_LIMIT_TWILIO=100
RATE_LIMIT_GOOGLE_MAPS=50
RATE_LIMIT_DEFAULT_PROVIDER=60

# ── Caching (GET responses) ───────────────────────────────────────────────────
# TTL in seconds. Set to 0 to disable caching for a provider.
# Uses Redis when available, falls back to in-memory automatically.
CACHE_TTL_OPENAI=0
CACHE_TTL_STRIPE=30
CACHE_TTL_GITHUB=120
CACHE_TTL_TWILIO=60
CACHE_TTL_GOOGLE_MAPS=300
CACHE_TTL_DEFAULT=60
CACHE_MAX_MEMORY=500

# ── Provider Master Keys ──────────────────────────────────────────────────────
# These are YOUR master-level keys. Tenants use a GOD API key; you proxy using
# these keys (or per-tenant keys stored in the DB).

# OpenAI (Required for /v1/openai/* routes)
OPENAI_API_KEY=sk-your-openai-key-here

# Stripe (Required for /v1/stripe/* routes)
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here

# GitHub (Required for /v1/github/* routes)
GITHUB_TOKEN=ghp_your-github-personal-access-token

# Twilio (Required for /v1/twilio/* routes)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Google Maps (Required for /v1/google-maps/* routes)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
